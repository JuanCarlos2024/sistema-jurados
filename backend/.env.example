# ============================================================
# SISTEMA DE JURADOS - Variables de Entorno
# Copiar este archivo como .env y completar los valores
# ============================================================

# Puerto del servidor Express
PORT=3000

# URL del proyecto Supabase (obtenla en: Project Settings > API)
SUPABASE_URL=https://TU_PROYECTO.supabase.co

# Service Role Key (NO la anon key - esta tiene permisos completos)
# Obtenla en: Project Settings > API > service_role key
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Secreto para firmar los JWT del sistema
# Usa una cadena larga y aleatoria (mínimo 32 caracteres)
JWT_SECRET=cambia_esto_por_una_cadena_larga_y_aleatoria_segura_2024

# Duración del token JWT
JWT_EXPIRES_IN=8h

# Entorno
NODE_ENV=development

# URL del frontend (para CORS)
FRONTEND_URL=http://localhost:5500
